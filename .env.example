# ============================================================
# Database Configuration
# ============================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/docdb
SPRING_DATASOURCE_USERNAME=docuser
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# ============================================================
# Application Configuration
# ============================================================
SHOW_SQL=false
FORMAT_SQL=false
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=50MB
APP_UPLOAD_DIR=/app/uploads

# ============================================================
# CORS (comma-separated list of allowed origins)
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ============================================================
# Frontend API URL (used at build time)
# ============================================================
VITE_API_URL=http://localhost:8080
